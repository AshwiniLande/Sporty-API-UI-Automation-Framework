<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Automation Suite" parallel="methods" thread-count="2">

    <!-- Environment parameters -->
    <parameter name="env" value="qa"/>
    <parameter name="browser" value="chrome"/>

    <!-- Listeners for logging, reporting, and custom transformations -->
    <listeners>
        <listener class-name="utils.Listener"/>
        <listener class-name="utils.Transform"/>
    </listeners>

    <!-- Single test block using TestRunner -->
    <test name="Execution">
        <classes>
            <class name="runners.TestRunner"/>
        </classes>
    </test>

</suite>